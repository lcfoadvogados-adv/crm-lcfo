{
  "functions": {
    "api/transcrever.js": { "maxDuration": 60 }
  },
  "crons": [
    {
      "path": "/api/dje-busca?cron=1",
      "schedule": "0 11 * * 1-5"
    }
  ],
  "headers": [
    {
      "source": "/",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" }
      ]
    },
    {
      "source": "/index.html",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" }
      ]
    }
  ]
}
